# Copy to functions/.secret.local for emulator-compatible secret loading.
# The emulator stays deterministic unless functions/.env.local explicitly enables live OpenAI.
# When enabled, this key is used server-side for recommendations, IEP and assignment analysis,
# evidence audits, and text-to-speech. It is never included in the browser bundle.
OPENAI_API_KEY=
STUDENT_PIN_PEPPER=
