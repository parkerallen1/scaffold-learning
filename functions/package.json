{
  "name": "quiz-master-functions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "prebuild": "npm --prefix ../packages/domain run build",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run format:check && npm run typecheck"
  },
  "dependencies": {
    "@quiz-master/domain": "*",
    "firebase-admin": "14.2.0",
    "firebase-functions": "7.3.0",
    "openai": "6.48.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "prettier": "3.9.5",
    "typescript": "5.8.2"
  }
}
