# Public Firebase web configuration for the local-only demo project.
# Copy this file to .env.local. Do not put server secrets in VITE_* variables.
VITE_USE_EMULATORS=true
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-scaffold-learning.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-scaffold-learning
VITE_FIREBASE_APP_ID=demo-app-id
VITE_FIREBASE_STORAGE_BUCKET=demo-scaffold-learning.firebasestorage.app
# Required only when VITE_USE_EMULATORS=false. Use a reCAPTCHA Enterprise score-based site key.
VITE_FIREBASE_APPCHECK_SITE_KEY=
